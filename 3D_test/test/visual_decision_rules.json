{
    "ruleset_id":  "HVRA_3D_VISUAL_DECISION_RULES_V1",
    "purpose":  "Suitability gates for test-only 3D retrofit visual variants before rendering.",
    "opening_types":  {
                          "window":  "standard window or uncertain opening",
                          "sliding_glass_door":  "full-height sliding glazed door or balcony door",
                          "balcony_door":  "operable glazed door with balcony or external threshold"
                      },
    "global_rules":  [
                         "Exterior shading, awnings, trellis, vegetation-on-window, and facade-mounted systems require an external wall and facade permission/owner approval.",
                         "Balcony or planter-based strategies require confirmed balcony/outdoor maintenance access.",
                         "Interior curtains, drapes, roller shades, and plant corners are renter-friendlier because they do not alter the facade.",
                         "For sliding glass doors, avoid small slatted systems that obstruct sliding operation or frequent passage unless a product-specific track detail is confirmed."
                     ],
    "variant_rules":  {
