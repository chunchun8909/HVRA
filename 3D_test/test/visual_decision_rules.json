                                                                               "balcony_door"
                                                                           ],
                                                 "placement_side":  "interior",
                                                 "suitability":  "good_for_sliding_glass_door",
                                                 "notes":  "Soft drapes can cover large glazed doors without modifying the facade."
                                             },
                          "sheer_curtain":  {
                                                "allowed_opening_types":  [
                                                                              "window",
                                                                              "sliding_glass_door",
                                                                              "balcony_door"
                                                                          ],
                                                "placement_side":  "interior",
                                                "suitability":  "good_for_daylight_diffusion",
                                                "notes":  "Useful for visual comfort, but thermal benefit is limited unless paired with solar-control strategy."
                                            },
                          "roller_shade":  {
                                               "allowed_opening_types":  [
                                                                             "window",
                                                                             "sliding_glass_door",
                                                                             "balcony_door"
                                                                         ],
                                               "placement_side":  "interior",
                                               "suitability":  "conditional_for_large_doors",
                                               "notes":  "For sliding doors, render as a wide or split shade and keep the passage side clear."
