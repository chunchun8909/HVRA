# Neo4j Knowledge Graph
USE_MOCK_NEO4J=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

# Ollama Local LLM
USE_MOCK_LLM=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_RETRIES=2

# Gemini Visual Generation
USE_MOCK_GEMINI=true
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash

# Spatial Engines
USE_MOCK_LGTNET=true
LGTNET_ROOT=C:\Users\Morris\OneDrive\Desktop\LGTNet
LGTNET_PYTHON=C:\Users\Morris\OneDrive\Desktop\LGTNet\.venv\Scripts\python.exe
USE_MOCK_SAM3=true
SAM3_ROOT=C:\Users\Morris\OneDrive\Desktop\LGTNet\_sam3_test
SAM3_PYTHON=C:\Users\Morris\OneDrive\Desktop\LGTNet\.venv_sam3\Scripts\python.exe

# Risk Map
USE_MOCK_RISK_MAP=true
RISK_MAP_DATA_ROOT=C:\Users\Morris\OneDrive\Desktop\hvra_test_run\risk_map\dataset
RISK_MAP_BOUNDING_BOX_RADIUS_M=250
USE_SYNTHETIC_UHI=true
USE_INFRARED_CITY=false
INFRARED_API_KEY=your_infrared_city_key_here
INFRARED_BASE_URL=https://api.infrared.city/v2
INFRARED_CITY_CACHE_JSON=C:\Users\Morris\OneDrive\Desktop\hvra_test_run\risk_map\dataset\infrared_city\infrared_city_context.json
INFRARED_CITY_FORCE_REFRESH=false

# Optional 3D Asset Registry Smoke Test
# Used only by 3D_test/run_lgtnet_asset_registry_test.py
ASSET_REGISTRY_API_URL=
ASSET_REGISTRY_API_KEY=

